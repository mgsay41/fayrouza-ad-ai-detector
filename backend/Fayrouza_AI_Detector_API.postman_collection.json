		{
			"name": "Async Moderation (Queue)",
			"item": [
				{
					"name": "POST /api/ads/moderate",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-Key",
								"value": "{{internal_api_key}}",
								"description": "Internal scope API key"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"ad_id\": 456,\n\t\"ad_title\": \"2019 Toyota Corolla - Excellent Condition\",\n\t\"ad_description\": \"Selling my 2019 Toyota Corolla, 80,000 km, automatic transmission. Full service history at Toyota dealer. New tires, AC works perfectly. Price is negotiable.\",\n\t\"ad_price\": 650000,\n\t\"ad_category\": \"Cars\",\n\t\"image\": \"https://example.com/corolla2019.jpg\",\n\t\"user_id\": 42,\n\t\"callback_url\": \"https://your-server.com/callback/moderation\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/ads/moderate",
							"host": ["{{base_url}}"],
							"path": ["api", "ads", "moderate"]
						},
						"description": "Asynchronous ad moderation. Adds the ad to a Redis-backed queue for processing. Returns immediately with a job ID.\n\n**Required fields:** `ad_id`, `ad_title`, `ad_description`, `ad_price`, `ad_category`\n**Optional fields:** `image` (URL), `user_id`, `callback_url`\n\nIf `callback_url` is provided, the full moderation result will be POSTed there when processing completes."
					},
					"response": [
						{
							"name": "202 - Job Queued",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" },
									{ "key": "X-API-Key", "value": "{{internal_api_key}}" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n\t\"ad_id\": 456,\n\t\"ad_title\": \"Toyota Corolla\",\n\t\"ad_description\": \"Excellent condition\",\n\t\"ad_price\": 650000,\n\t\"ad_category\": \"Cars\"\n\t}"
								},
								"url": {
									"raw": "{{base_url}}/api/ads/moderate",
									"host": ["{{base_url}}"],
									"path": ["api", "ads", "moderate"]
								}
							},
