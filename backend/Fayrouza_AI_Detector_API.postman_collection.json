		{
			"name": "Admin",
			"item": [
				{
					"name": "POST /api/admin/override",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-Key",
								"value": "{{admin_api_key}}",
								"description": "Admin scope API key"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"ad_id\": 456,\n\t\"decision\": \"AUTO_APPROVED\",\n\t\"reason\": \"Admin reviewed the ad manually and confirmed it complies with marketplace policies.\",\n\t\"reviewer_id\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/admin/override",
							"host": ["{{base_url}}"],
							"path": ["api", "admin", "override"]
						},
						"description": "Manual admin decision override. Updates the ad status in the Fayrouza marketplace and logs an audit entry.\n\n**Required fields:**\n- `ad_id`: Positive integer\n- `decision`: One of `AUTO_APPROVED`, `NEEDS_REVIEW`, `AUTO_REJECTED`\n- `reason`: 1-1000 characters\n- `reviewer_id`: Positive integer\n\n**Fayrouza status mapping:**\n- `AUTO_APPROVED` -> status 1 (active)\n- `NEEDS_REVIEW` -> status 3 (pending/review)\n- `AUTO_REJECTED` -> status 4 (rejected)"
					},
					"response": [
						{
							"name": "200 - Override Successful",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" },
									{ "key": "X-API-Key", "value": "{{admin_api_key}}" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n\t\"ad_id\": 456,\n\t\"decision\": \"AUTO_APPROVED\",\n\t\"reason\": \"Admin approved after review.\",\n\t\"reviewer_id\": 5\n\t}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/override",
									"host": ["{{base_url}}"],
									"path": ["api", "admin", "override"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{ "key": "Content-Type", "value": "application/json" }
							],
							"body": "{\n\t\"success\": true,\n\t\"data\": {\n\t\t\"ad_id\": 456,\n\t\t\"decision\": \"AUTO_APPROVED\",\n\t\t\"fayrouza_status\": 1,\n\t\t\"reason\": \"Admin approved after review.\",\n\t\t\"reviewer_id\": 5,\n\t\t\"overridden_at\": \"2026-04-25T12:00:00.000Z\"\n\t}\n}",
							"_postman_previewlanguage": "json"
						},
						{
							"name": "400 - Invalid Decision",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" },
									{ "key": "X-API-Key", "value": "{{admin_api_key}}" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n\t\"ad_id\": 456,\n\t\"decision\": \"INVALID\",\n\t\"reason\": \"test\",\n\t\"reviewer_id\": 5\n\t}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/override",
									"host": ["{{base_url}}"],
									"path": ["api", "admin", "override"]
								}
							},
							"status": "Bad Request",
							"code": 400,
							"header": [
								{ "key": "Content-Type", "value": "application/json" }
