							"body": "{\n\t\"success\": false,\n\t\"error\": \"Validation failed\",\n\t\"code\": \"VALIDATION_ERROR\",\n\t\"details\": [\n\t\t{\n\t\t\t\"field\": \"decision\",\n\t\t\t\"message\": \"Invalid enum value. Expected 'AUTO_APPROVED' | 'NEEDS_REVIEW' | 'AUTO_REJECTED'\"\n\t\t}\n\t]\n}",
							"_postman_previewlanguage": "json"
						}
					]
				},
				{
